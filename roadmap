// ============ Backend call ============
async function askMentor(messages, profile) {
  const response = await fetch(BACKEND_URL, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      messages: messages.map((m) => ({ role: m.role, content: m.content })),
      profile,
    }),
  });
  const data = await response.json();
  if (!response.ok) {
    throw new Error(data.error || "Server error");
  }
  return data.reply || "Hmm, I didn't catch that — could you try asking again?";
}

// Generates a personalized roadmap for this specific student via the backend.
// Adds stable ids to each milestone (the AI only returns title/detail).
async function generateRoadmap(profile) {
  const response = await fetch(ROADMAP_URL, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ profile }),
  });
  const data = await response.json();
  if (!response.ok || !data.roadmap) {
    throw new Error(data.error || "Failed to generate roadmap");
  }

  const withIds = {};
  for (const grade of GRADE_LABELS) {
    const milestones = data.roadmap[grade] || [];
    withIds[grade] = milestones.map((m, i) => ({
      id: `${grade.slice(0, 2).toLowerCase()}${i}`,
      title: m.title,
      detail: m.detail,
    }));
  }
  return { roadmap: withIds, summary: data.summary || "" };
}

