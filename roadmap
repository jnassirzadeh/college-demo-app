// ============ Research / Building Trail Screen ============
function buildResearchSteps(profile) {
  const field = profile.fieldDirection || "your interests";
  const place = profile.school || profile.city || "your area";
  return [
    `Reading through your profile, ${profile.name}...`,
    `Searching for ${field.toLowerCase()} clubs near ${place}...`,
    `Looking into competitions and programs in ${field.toLowerCase()}...`,
    `Checking volunteer opportunities near ${profile.city}...`,
    `Mapping out your four-year trail...`,
    `Putting it all together...`,
  ];
}

function ResearchScreen({ profile, onComplete }) {
  const [stepIndex, setStepIndex] = useState(0);
  const [error, setError] = useState(null);
  const steps = buildResearchSteps(profile);

  useEffect(() => {
    // Cycle through display messages while the real request runs in the background
    const interval = setInterval(() => {
      setStepIndex((i) => Math.min(i + 1, steps.length - 1));
    }, 2200);

    generateRoadmap(profile)
      .then((result) => {
        clearInterval(interval);
        onComplete(result);
      })
      .catch((e) => {
        clearInterval(interval);
        setError(e.message);
      });

    return () => clearInterval(interval);
  }, []);

  if (error) {
    return (
      <SafeAreaView style={[styles.screenBase, { justifyContent: "center", alignItems: "center", padding: 28 }]}>
        <Text style={[styles.h2, { textAlign: "center", marginBottom: 8 }]}>Hmm, that didn't work</Text>
        <Text style={[styles.detailText, { textAlign: "center" }]}>
          We couldn't reach the research service. We'll start you off with a general trail instead — you can always ask your mentor for personalized suggestions anytime.
        </Text>
        <TouchableOpacity
          style={[styles.primaryButton, { marginTop: 12, paddingHorizontal: 24 }]}
          onPress={() => onComplete({ roadmap: FALLBACK_ROADMAP, summary: "" })}
        >
          <Text style={styles.primaryButtonText}>Continue anyway</Text>
        </TouchableOpacity>
      </SafeAreaView>
    );
  }

  return (
    <SafeAreaView style={[styles.screenBase, { justifyContent: "center", alignItems: "center", padding: 28 }]}>
      <Compass size={32} color={COLORS.coral} style={{ marginBottom: 20 }} />
      <Text style={[styles.h1, { textAlign: "center", fontSize: 22 }]}>Building your trail</Text>
      <Text style={[styles.detailText, { textAlign: "center", marginTop: 8, marginBottom: 28 }]}>
        {steps[stepIndex]}
      </Text>
      <View style={{ flexDirection: "row", gap: 6 }}>
        {steps.map((_, i) => (
          <View
            key={i}
            style={{
              width: 8,
              height: 8,
              borderRadius: 4,
              backgroundColor: i <= stepIndex ? COLORS.coral : COLORS.borderStrong,
            }}
          />
        ))}
      </View>
    </SafeAreaView>
  );
}

// ============ Trail Map ============
function TrailMap({ profile, completed, setCompleted, setSelectedMilestone, roadmap, summary }) {
  const currentGradeIdx = GRADE_LABELS.indexOf(profile.grade);

  return (
    <ScrollView style={{ flex: 1 }} contentContainerStyle={{ padding: 20, paddingBottom: 100 }}>
      <View style={{ marginBottom: 28 }}>
        <Text style={styles.eyebrow}>YOUR TRAIL</Text>
        <Text style={styles.h1}>{profile.name}'s path to acceptance day</Text>
        {!!summary && <Text style={[styles.detailText, { marginTop: 8, marginBottom: 0 }]}>{summary}</Text>}
      </View>

      {GRADE_LABELS.map((grade, gi) => {
        const isCurrent = gi === currentGradeIdx;
        const isFuture = gi > currentGradeIdx;
        const isPast = gi < currentGradeIdx;
        const color = GRADE_COLORS[grade];

        return (
          <View key={grade} style={{ flexDirection: "row" }}>
            {/* Trail line + node column */}
            <View style={{ width: 24, alignItems: "center" }}>
              <View
                style={{
                  width: 24,
                  height: 24,
                  borderRadius: 12,
                  backgroundColor: isFuture ? COLORS.white : color,
                  borderWidth: 3,
                  borderColor: isFuture ? COLORS.borderStrong : color,
                  alignItems: "center",
                  justifyContent: "center",
                }}
              >
                {isCurrent && <View style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: COLORS.white }} />}
              </View>
              {gi < GRADE_LABELS.length - 1 && (
                <View
                  style={{
                    width: 3,
                    flex: 1,
                    backgroundColor: isPast || isCurrent ? color : COLORS.borderStrong,
                    marginTop: 2,
                  }}
                />
              )}
            </View>

            {/* Content column */}
            <View style={{ flex: 1, marginLeft: 14, marginBottom: 22, opacity: isFuture ? 0.6 : 1 }}>
              <Text style={[styles.h2, { color: isFuture ? COLORS.faint : COLORS.ink, marginBottom: 10 }]}>
                {grade}
                {isCurrent && <Text style={{ fontSize: 12, color, fontWeight: "700" }}>  · YOU ARE HERE</Text>}
              </Text>

              {(roadmap[grade] || []).map((m) => {
                const done = completed.has(m.id);
                return (
                  <TouchableOpacity
                    key={m.id}
                    onPress={() => setSelectedMilestone({ ...m, grade, color })}
                    style={styles.milestoneCard}
                  >
                    {done ? <CheckCircle2 size={20} color={color} /> : <Circle size={20} color="#D8D2C4" />}
                    <Text
                      style={[
                        styles.milestoneText,
                        done && { textDecorationLine: "line-through" },
                      ]}
                    >
                      {m.title}
                    </Text>
                  </TouchableOpacity>
                );
              })}
            </View>
          </View>
        );
      })}
    </ScrollView>
  );
}

function MilestoneSheet({ milestone, completed, setCompleted, onClose, onAskMentor }) {
  if (!milestone) return null;
  const done = completed.has(milestone.id);

  return (
    <Modal visible transparent animationType="slide" onRequestClose={onClose}>
      <TouchableOpacity style={styles.modalOverlay} activeOpacity={1} onPress={onClose}>
        <TouchableOpacity activeOpacity={1} style={styles.modalSheet}>
          <View style={styles.modalHandle} />
          <Text style={[styles.eyebrow, { color: milestone.color }]}>{milestone.grade.toUpperCase()}</Text>
          <Text style={styles.h2}>{milestone.title}</Text>
          <Text style={styles.detailText}>{milestone.detail}</Text>
          <View style={{ flexDirection: "row", gap: 10, marginTop: 8 }}>
            <TouchableOpacity
              onPress={() =>
                setCompleted((prev) => {
                  const next = new Set(prev);
                  if (done) next.delete(milestone.id);
                  else next.add(milestone.id);
                  return next;
                })
              }
              style={[
                styles.primaryButton,
                { flex: 1, backgroundColor: done ? COLORS.white : milestone.color, borderWidth: done ? 1 : 0, borderColor: COLORS.borderStrong },
              ]}
            >
              <Text style={[styles.primaryButtonText, { color: done ? COLORS.ink : COLORS.white }]}>
                {done ? "Mark as not done" : "Mark as done"}
              </Text>
            </TouchableOpacity>
            <TouchableOpacity
              onPress={() => onAskMentor(milestone.title)}
              style={[styles.primaryButton, { flex: 1, backgroundColor: COLORS.white, borderWidth: 1, borderColor: COLORS.borderStrong }]}
            >
              <Text style={[styles.primaryButtonText, { color: COLORS.ink }]}>Ask mentor</Text>
            </TouchableOpacity>
          </View>
        </TouchableOpacity>
      </TouchableOpacity>
    </Modal>
  );
}

// ============ Lightweight Markdown Renderer ============
// Hand-rolled, no external dependency — avoids compatibility issues with
// unmaintained packages on newer React/React Native versions.
// Supports: **bold**, bullet lines (- or *), numbered lines, plain paragraphs.

function renderInlineBold(line, baseStyle) {
  const parts = line.split(/(\*\*[^*]+\*\*)/g).filter((p) => p.length > 0);
  return parts.map((part, i) => {
    if (part.startsWith("**") && part.endsWith("**")) {
      return (
        <Text key={i} style={[baseStyle, { fontWeight: "700" }]}>
          {part.slice(2, -2)}
        </Text>
      );
    }
    return <Text key={i} style={baseStyle}>{part}</Text>;
  });
}

function SimpleMarkdown({ text }) {
  if (!text) return null;
  const lines = text.split("\n");
  const baseStyle = { color: COLORS.ink, fontSize: 14.5, lineHeight: 21 };

  return (
    <View>
      {lines.map((line, i) => {
        const trimmed = line.trim();
        if (trimmed === "") {
          return <View key={i} style={{ height: 6 }} />;
        }
        const bulletMatch = trimmed.match(/^[-*]\s+(.*)/);
        const numberedMatch = trimmed.match(/^(\d+)\.\s+(.*)/);
        const headingMatch = trimmed.match(/^#{1,3}\s+(.*)/);

        if (headingMatch) {
          return (
            <Text key={i} style={{ fontSize: 16.5, fontWeight: "700", color: COLORS.ink, marginTop: 4, marginBottom: 4 }}>
              {renderInlineBold(headingMatch[1], { fontSize: 16.5, fontWeight: "700", color: COLORS.ink })}
            </Text>
          );
        }
        if (bulletMatch) {
          return (
            <View key={i} style={{ flexDirection: "row", marginBottom: 4, paddingLeft: 4 }}>
              <Text style={{ color: COLORS.coral, marginRight: 6, fontSize: 14.5 }}>•</Text>
              <Text style={[baseStyle, { flex: 1 }]}>{renderInlineBold(bulletMatch[1], baseStyle)}</Text>
            </View>
          );
        }
        if (numberedMatch) {
          return (
            <View key={i} style={{ flexDirection: "row", marginBottom: 4, paddingLeft: 4 }}>
              <Text style={{ color: COLORS.coral, marginRight: 6, fontSize: 14.5, fontWeight: "700" }}>{numberedMatch[1]}.</Text>
              <Text style={[baseStyle, { flex: 1 }]}>{renderInlineBold(numberedMatch[2], baseStyle)}</Text>
            </View>
          );
        }
        return (
          <Text key={i} style={[baseStyle, { marginBottom: 6 }]}>
            {renderInlineBold(trimmed, baseStyle)}
          </Text>
        );
      })}
    </View>
  );
}

// ============ Mentor Chat ============
function MentorChat({ profile, messages, setMessages, pendingPrompt, clearPendingPrompt }) {
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);
  const scrollRef = useRef(null);

  useEffect(() => {
    setTimeout(() => scrollRef.current?.scrollToEnd({ animated: true }), 100);
  }, [messages, loading]);

  useEffect(() => {
    if (pendingPrompt) {
      send(pendingPrompt);
      clearPendingPrompt();
    }
  }, [pendingPrompt]);

  async function send(text) {
    const content = (text ?? input).trim();
    if (!content || loading) return;
    const userMsg = { role: "user", content };
    const newMessages = [...messages, userMsg];
    setMessages(newMessages);
    setInput("");
    setLoading(true);
    try {
      const reply = await askMentor(newMessages, profile);
      setMessages((m) => [...m, { role: "assistant", content: reply }]);
    } catch (e) {
      setMessages((m) => [...m, { role: "assistant", content: "Sorry, I had trouble responding — try again in a moment." }]);
    } finally {
      setLoading(false);
    }
  }

  return (
    <KeyboardAvoidingView style={{ flex: 1 }} behavior={Platform.OS === "ios" ? "padding" : undefined}>
      <View style={{ padding: 20, paddingBottom: 12, borderBottomWidth: 1, borderBottomColor: COLORS.border }}>
        <Text style={styles.eyebrow}>YOUR MENTOR</Text>
        <Text style={[styles.h1, { fontSize: 22 }]}>Ask me anything</Text>
      </View>

      <ScrollView ref={scrollRef} style={{ flex: 1 }} contentContainerStyle={{ padding: 16 }}>
        {messages.length === 0 && (
          <View style={{ alignItems: "center", marginTop: 24 }}>
            <Sparkles size={26} color={COLORS.faint} style={{ marginBottom: 10 }} />
            <Text style={{ fontSize: 14, color: COLORS.faint, textAlign: "center", paddingHorizontal: 30, marginBottom: 16, lineHeight: 20 }}>
              Ask about classes, activities, testing, or just talk through what's on your mind about school.
            </Text>
            <View style={{ width: "100%", gap: 8, paddingHorizontal: 8 }}>
              {[
                `Find clubs near ${profile.school || profile.city} that fit my interests`,
                `What volunteer opportunities are near ${profile.city}?`,
                "What should I be doing right now for my grade?",
              ].map((p) => (
                <TouchableOpacity key={p} onPress={() => send(p)} style={styles.promptChip}>
                  <Text style={styles.promptChipText}>{p}</Text>
                </TouchableOpacity>
              ))}
            </View>
          </View>
        )}

        {messages.map((m, i) => (
          <View
            key={i}
            style={{
              alignSelf: m.role === "user" ? "flex-end" : "flex-start",
              maxWidth: "85%",
              backgroundColor: m.role === "user" ? COLORS.coral : COLORS.white,
              borderWidth: m.role === "user" ? 0 : 1,
              borderColor: COLORS.border,
              borderRadius: 16,
              padding: 12,
              marginBottom: 10,
            }}
          >
            {m.role === "user" ? (
              <Text style={{ color: COLORS.white, fontSize: 14.5, lineHeight: 20 }}>{m.content}</Text>
            ) : (
              <SimpleMarkdown text={m.content} />
            )}
          </View>
        ))}

        {loading && (
          <View style={{ alignSelf: "flex-start", backgroundColor: COLORS.white, borderWidth: 1, borderColor: COLORS.border, borderRadius: 16, padding: 12 }}>
            <Text style={{ color: COLORS.faint, fontSize: 14 }}>thinking...</Text>
          </View>
        )}
      </ScrollView>

      <View style={{ flexDirection: "row", gap: 8, padding: 14, borderTopWidth: 1, borderTopColor: COLORS.border }}>
        <TextInput
          value={input}
          onChangeText={setInput}
          onSubmitEditing={() => send()}
          placeholder="Type a question..."
          placeholderTextColor={COLORS.faint}
          style={[styles.input, { flex: 1 }]}
        />
        <TouchableOpacity onPress={() => send()} disabled={loading} style={styles.sendButton}>
          <Send size={18} color={COLORS.white} />
        </TouchableOpacity>
      </View>
    </KeyboardAvoidingView>
  );
}

// ============ Root App ============
export default function App() {
  const [profile, setProfile] = useState(null);
  const [roadmapData, setRoadmapData] = useState(null); // { roadmap, summary } once generated
  const [tab, setTab] = useState("trail");
  const [completed, setCompleted] = useState(new Set());
  const [selectedMilestone, setSelectedMilestone] = useState(null);
  const [messages, setMessages] = useState([]);
  const [pendingPrompt, setPendingPrompt] = useState(null);

  if (!profile) {
    return <Onboarding onComplete={setProfile} />;
  }

  if (!roadmapData) {
    return <ResearchScreen profile={profile} onComplete={setRoadmapData} />;
  }

  return (
    <SafeAreaView style={styles.screenBase}>
      <View style={{ flex: 1 }}>
        {tab === "trail" ? (
          <TrailMap
            profile={profile}
            completed={completed}
            setCompleted={setCompleted}
            setSelectedMilestone={setSelectedMilestone}
            roadmap={roadmapData.roadmap}
            summary={roadmapData.summary}
          />
        ) : (
          <MentorChat
            profile={profile}
            messages={messages}
            setMessages={setMessages}
            pendingPrompt={pendingPrompt}
            clearPendingPrompt={() => setPendingPrompt(null)}
          />
        )}
        <MilestoneSheet
          milestone={selectedMilestone}
          completed={completed}
          setCompleted={setCompleted}
          onClose={() => setSelectedMilestone(null)}
          onAskMentor={(title) => {
            setSelectedMilestone(null);
            setTab("chat");
            setPendingPrompt(`Can you help me think through this: "${title}"?`);
          }}
        />
      </View>

      <View style={styles.tabBar}>
        {[
          { key: "trail", label: "Trail", Icon: MapIcon },
          { key: "chat", label: "Mentor", Icon: MessageCircle },
        ].map(({ key, label, Icon }) => (
          <TouchableOpacity key={key} onPress={() => setTab(key)} style={styles.tabButton}>
            <Icon size={20} color={tab === key ? COLORS.coral : COLORS.faint} />
            <Text style={[styles.tabLabel, { color: tab === key ? COLORS.coral : COLORS.faint }]}>{label}</Text>
          </TouchableOpacity>
        ))}
      </View>
    </SafeAreaView>
  );
}

